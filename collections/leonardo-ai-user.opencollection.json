{
  "opencollection": "1.0.0",
  "info": {
    "name": "Leonardo.AI User API",
    "version": "v1.0.0"
  },
  "request": {
    "auth": {
      "type": "bearer",
      "token": "{{bearerToken}}"
    }
  },
  "items": [
    {
      "info": {
        "name": "User",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Get user information",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://cloud.leonardo.ai/api/rest/v1/me"
          },
          "docs": "This endpoint will return your user information such as your user id, username, token renewal date and current amounts of the following: subscription tokens, gpt (prompt generation) tokens, and model training tokens"
        }
      ]
    }
  ],
  "bundled": true
}