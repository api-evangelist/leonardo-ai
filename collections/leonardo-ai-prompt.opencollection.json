{
  "opencollection": "1.0.0",
  "info": {
    "name": "Leonardo.AI Prompt API",
    "version": "v1.0.0"
  },
  "request": {
    "auth": {
      "type": "bearer",
      "token": "{{bearerToken}}"
    }
  },
  "items": [
    {
      "info": {
        "name": "Prompt",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Generate a Random prompt",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://cloud.leonardo.ai/api/rest/v1/prompt/random"
          },
          "docs": "This endpoint returns a random prompt"
        },
        {
          "info": {
            "name": "Improve a Prompt",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://cloud.leonardo.ai/api/rest/v1/prompt/improve",
            "body": {
              "type": "json",
              "data": "{}"
            }
          },
          "docs": "This endpoint returns a improved prompt"
        }
      ]
    }
  ],
  "bundled": true
}