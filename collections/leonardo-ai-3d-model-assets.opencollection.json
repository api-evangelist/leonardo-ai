{
  "opencollection": "1.0.0",
  "info": {
    "name": "Leonardo.AI 3D Model Assets API",
    "version": "v1.0.0"
  },
  "request": {
    "auth": {
      "type": "bearer",
      "token": "{{bearerToken}}"
    }
  },
  "items": [
    {
      "info": {
        "name": "3D Model Assets",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Upload 3D Model",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://cloud.leonardo.ai/api/rest/v1/models-3d/upload",
            "body": {
              "type": "json",
              "data": "{}"
            }
          },
          "docs": "This endpoint returns presigned details to upload a 3D model to S3"
        },
        {
          "info": {
            "name": "Get 3D models by user ID",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://cloud.leonardo.ai/api/rest/v1/models-3d/user/:userId",
            "params": [
              {
                "name": "offset",
                "value": "",
                "type": "query"
              },
              {
                "name": "limit",
                "value": "",
                "type": "query"
              },
              {
                "name": "userId",
                "value": "",
                "type": "path"
              }
            ],
            "body": {
              "type": "json",
              "data": "{}"
            }
          },
          "docs": "This endpoint returns all 3D models by a specific user"
        },
        {
          "info": {
            "name": "Get 3D Model by ID",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://cloud.leonardo.ai/api/rest/v1/models-3d/:id",
            "params": [
              {
                "name": "offset",
                "value": "",
                "type": "query"
              },
              {
                "name": "limit",
                "value": "",
                "type": "query"
              },
              {
                "name": "id",
                "value": "",
                "type": "path",
                "description": "_\"id\" is required (enter it either in parameters or request body)_"
              }
            ],
            "body": {
              "type": "json",
              "data": "{}"
            }
          },
          "docs": "This endpoint gets the specific 3D model"
        },
        {
          "info": {
            "name": "Delete 3D Model by ID",
            "type": "http"
          },
          "http": {
            "method": "DELETE",
            "url": "https://cloud.leonardo.ai/api/rest/v1/models-3d/:id",
            "params": [
              {
                "name": "id",
                "value": "",
                "type": "path",
                "description": "_\"id\" is required (enter it either in parameters or request body)_"
              }
            ],
            "body": {
              "type": "json",
              "data": "{}"
            }
          },
          "docs": "This endpoint deletes the specific 3D Model"
        }
      ]
    }
  ],
  "bundled": true
}